title: Election Simulation
set-jump: post_election


- @1991: 1991 historical scenario
- @1995: 1995 historical scenario
- @1999: 1999 historical scenario

@1991
on-arrival: {!
Q.workers = 46; // industry and trade
Q.old_middle = 13; // "old mittelstand"
// 16.4 trade & commerce, 6.6 public and private services, 4.4 domestic help
Q.new_middle = 14; // "new mittelstand"
Q.rural = 25; // agriculture and forestry employment... but many of those are proletarians so...
// source: https://surface.syr.edu/cgi/viewcontent.cgi?filename=3&article=1016&context=books&type=additional page 43, table 3.3
Q.minorities = 8.6;
Q.religious = 30;

Q.classes = ['workers', 'old_middle', 'new_middle', 'rural', 'minorities', 'religious'];
Q.parties = ['shp', 'tsp', 'anap', 'dsp', 'dyp', 'mcp', 'refah', 'other'];

// Support for party by social group
// they don't have to sum to 100 since the electoral calculations will be normalized.
Q.workers_shp = 65;
Q.workers_tsp = 20;
Q.workers_anap = 5;
Q.workers_dsp = 0;
Q.workers_dyp = 0;
Q.workers_mcp = 5;
Q.workers_refah = 0;
Q.workers_other = 10;

Q.old_middle_shp = 5;
Q.old_middle_tsp = 0;
Q.old_middle_anap = 5;
Q.old_middle_dsp= 10;
Q.old_middle_dyp = 25;
Q.old_middle_mcp = 25;
Q.old_middle_refah = 10;
Q.old_middle_other = 10;

Q.new_middle_shp = 5;
Q.new_middle_tsp = 0;
Q.new_middle_anap = 10;
Q.new_middle_dsp= 25;
Q.new_middle_dyp = 25;
Q.new_middle_mcp = 10;
Q.new_middle_refah = 5;
Q.new_middle_other = 15;

Q.rural_shp = 10;
Q.rural_tsp = 0;
Q.rural_anap = 5;
Q.rural_dsp= 5;
Q.rural_dyp = 15;
Q.rural_mcp = 45;
Q.rural_refah = 5;
Q.rural_other = 10;

Q.minorities_shp = 25;
Q.minorities_tsp = 55;
Q.minorities_anap = 1;
Q.minorities_dsp = 0;
Q.minorities_dyp = 0;
Q.minorities_mcp = 5;
Q.minorities_refah = 15;
Q.minorities_other = 9;

Q.religious_shp = 15;
Q.religious_tsp = 5;
Q.religious_anap = 50;
Q.religious_dsp = 0;
Q.religious_dyp = 5;
Q.religious_mcp = 5;
Q.religious_refah = 0;
Q.religious_other = 10;
!}
go-to: election_algorithm
set-jump: post_election

